{
  "name": "bba-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Building Better Algorithms — React frontend (S3 + CloudFront)",
  "license": "SEE LICENSE IN ../LICENSE.md",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint . && node --import tsx/esm node_modules/prettier/bin/prettier.cjs --check .",
    "format": "node --import tsx/esm node_modules/prettier/bin/prettier.cjs --write .",
    "codegen": "graphql-codegen"
  },
  "dependencies": {
    "@lordicon/element": "^2.2.0",
    "@types/react-simple-maps": "^3.0.6",
    "@urql/exchange-auth": "^3.0.0",
    "aws-amplify": "^6.17.0",
    "canvas-confetti": "^1.9.4",
    "graphql": "^16.14.0",
    "gsap": "^3.15.0",
    "prop-types": "^15.8.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.15.1",
    "react-simple-maps": "^3.0.0",
    "urql": "^5.0.2",
    "wonka": "^6.3.6",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-codegen/client-preset": "^6.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "browserslist": "^4.28.2",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jiti": "^2.7.0",
    "lightningcss": "^1.32.0",
    "prettier": "^3.8.3",
    "prettier-plugin-ignored": "^1.0.0",
    "ts-jest": "^29.4.10",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14"
  }
}
