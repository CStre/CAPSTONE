# Copy to .env for local development.  Real values live in SSM Parameter Store in AWS.

# --- runtime ---
NODE_ENV=development
PORT=4000

# --- DynamoDB ---
# Local dev points at DynamoDB Local (see docker-compose.yml); leave AWS_REGION as-is.
DYNAMODB_TABLE=bba-prefs-local
DYNAMODB_ENDPOINT=http://localhost:8000
AWS_REGION=us-east-1
# DynamoDB Local accepts any credentials; real AWS uses the IAM role / CLI profile.
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# --- auth ---
# AUTH_MODE=dev bypasses Cognito for local work (no pool exists until Phase 3).
# In dev mode the request identity comes from the x-dev-* headers below, or a default.
AUTH_MODE=dev
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# --- Unsplash ---
# Leave blank locally to use placeholder images instead of calling the API.
UNSPLASH_ACCESS_KEY=
